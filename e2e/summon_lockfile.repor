# E2E: `enozunu summon` locks mutable Git selectors in enozunu.lock.json and
# resolves from that record on later runs.
#
# Each case builds a local repository inside the case workspace and points the
# manifest at it with a `file://` URL, so the real resolver runs while the run
# stays offline and deterministic. The manifest is written with a `SOURCE_URL`
# placeholder and substituted by a shell step, because the workspace path is
# only known at run time.
#
# The lock-first cases give the branch tip different content from the locked
# commit, so a case cannot pass by accidentally re-resolving the branch head.
#
# Run-time commit ids are asserted through shell `grep` steps, as in the
# selector e2e cases, because the expected id is only known once the fixture
# repository exists.
#
# Repository-creating steps run with `GIT_CONFIG_GLOBAL=/dev/null
# GIT_CONFIG_NOSYSTEM=1` so ambient developer configuration — commit signing
# above all — cannot make the fixture fail to build outside CI.

case "summon creates the lock file and records the resolved branch commit" {
  $ GIT_CONFIG_GLOBAL=/dev/null GIT_CONFIG_NOSYSTEM=1 git init --quiet --initial-branch main source-repo
  $ git -C source-repo config user.email "e2e@example.com"
  $ git -C source-repo config user.name "e2e"
  write <"source-repo/skills/demo-skill/SKILL.md"> ```
    ---
    name: demo-skill
    description: demo skill resolved over git transport
    ---

    # Demo Skill
    ```
  $ GIT_CONFIG_GLOBAL=/dev/null GIT_CONFIG_NOSYSTEM=1 git -C source-repo add --all
  $ GIT_CONFIG_GLOBAL=/dev/null GIT_CONFIG_NOSYSTEM=1 git -C source-repo commit --quiet -m only
  write <"enozunu.kdl"> ```
    enozunu config-version=1 {
      provider {
        skills {
          skill "demo-skill" {
            git {
              url "SOURCE_URL"
              branch "main"
              path "skills/demo-skill"
            }
          }
        }
      }
      consumer {
        claude {
          use-skills "demo-skill"
        }
      }
    }
    ```
  $ sed -i "s|SOURCE_URL|file://$PWD/source-repo|" enozunu.kdl
  $ enozunu summon
  assert {
    exit 0
    stdout contains "created enozunu.lock.json"
    file <"enozunu.lock.json"> contains "\"version\": 1"
    file <"enozunu.lock.json"> contains "\"type\": \"branch\""
    file <"enozunu.lock.json"> contains "\"value\": \"main\""
  }
  # The recorded revision is the resolved branch head. Asserted through a shell
  # step because the expected id is only known at run time.
  $ head=$(git -C source-repo rev-parse main) && grep -q "\"resolved_revision\": \"$head\"" enozunu.lock.json
  assert {
    exit 0
  }
}

case "a second summon stays on the locked commit while the branch advances" {
  $ GIT_CONFIG_GLOBAL=/dev/null GIT_CONFIG_NOSYSTEM=1 git init --quiet --initial-branch main source-repo
  $ git -C source-repo config user.email "e2e@example.com"
  $ git -C source-repo config user.name "e2e"
  write <"source-repo/skills/demo-skill/SKILL.md"> ```
    ---
    name: demo-skill
    description: demo skill resolved over git transport
    ---

    # Demo Skill OLD
    ```
  $ GIT_CONFIG_GLOBAL=/dev/null GIT_CONFIG_NOSYSTEM=1 git -C source-repo add --all
  $ GIT_CONFIG_GLOBAL=/dev/null GIT_CONFIG_NOSYSTEM=1 git -C source-repo commit --quiet -m old
  write <"enozunu.kdl"> ```
    enozunu config-version=1 {
      provider {
        skills {
          skill "demo-skill" {
            git {
              url "SOURCE_URL"
              branch "main"
              path "skills/demo-skill"
            }
          }
        }
      }
      consumer {
        claude {
          use-skills "demo-skill"
        }
      }
    }
    ```
  $ sed -i "s|SOURCE_URL|file://$PWD/source-repo|" enozunu.kdl
  # First run locks the current head.
  $ enozunu summon
  assert {
    exit 0
    file <".claude/skills/demo-skill/SKILL.md"> contains "Demo Skill OLD"
  }
  # Advance the branch so the head no longer matches the locked commit.
  $ sed -i 's/Demo Skill OLD/Demo Skill NEW/' source-repo/skills/demo-skill/SKILL.md
  $ GIT_CONFIG_GLOBAL=/dev/null GIT_CONFIG_NOSYSTEM=1 git -C source-repo commit --quiet -am new
  $ enozunu summon
  assert {
    exit 0
    # The branch moved, but the default run materializes the locked commit and
    # leaves the lock file alone.
    file <".claude/skills/demo-skill/SKILL.md"> contains "Demo Skill OLD"
    not {
      file <".claude/skills/demo-skill/SKILL.md"> contains "Demo Skill NEW"
    }
    not {
      stdout contains "updated enozunu.lock.json"
    }
  }
}

case "summon --update follows the branch and rewrites the lock" {
  $ GIT_CONFIG_GLOBAL=/dev/null GIT_CONFIG_NOSYSTEM=1 git init --quiet --initial-branch main source-repo
  $ git -C source-repo config user.email "e2e@example.com"
  $ git -C source-repo config user.name "e2e"
  write <"source-repo/skills/demo-skill/SKILL.md"> ```
    ---
    name: demo-skill
    description: demo skill resolved over git transport
    ---

    # Demo Skill OLD
    ```
  $ GIT_CONFIG_GLOBAL=/dev/null GIT_CONFIG_NOSYSTEM=1 git -C source-repo add --all
  $ GIT_CONFIG_GLOBAL=/dev/null GIT_CONFIG_NOSYSTEM=1 git -C source-repo commit --quiet -m old
  write <"enozunu.kdl"> ```
    enozunu config-version=1 {
      provider {
        skills {
          skill "demo-skill" {
            git {
              url "SOURCE_URL"
              branch "main"
              path "skills/demo-skill"
            }
          }
        }
      }
      consumer {
        claude {
          use-skills "demo-skill"
        }
      }
    }
    ```
  $ sed -i "s|SOURCE_URL|file://$PWD/source-repo|" enozunu.kdl
  $ enozunu summon
  assert {
    exit 0
    file <".claude/skills/demo-skill/SKILL.md"> contains "Demo Skill OLD"
  }
  $ sed -i 's/Demo Skill OLD/Demo Skill NEW/' source-repo/skills/demo-skill/SKILL.md
  $ GIT_CONFIG_GLOBAL=/dev/null GIT_CONFIG_NOSYSTEM=1 git -C source-repo commit --quiet -am new
  $ enozunu summon --update
  assert {
    exit 0
    stdout contains "updated enozunu.lock.json"
    # An update run re-resolves the branch, so the new head wins.
    file <".claude/skills/demo-skill/SKILL.md"> contains "Demo Skill NEW"
    not {
      file <".claude/skills/demo-skill/SKILL.md"> contains "Demo Skill OLD"
    }
  }
  # The rewritten lock records the advanced head.
  $ head=$(git -C source-repo rev-parse main) && grep -q "\"resolved_revision\": \"$head\"" enozunu.lock.json
  assert {
    exit 0
  }
}

case "summon --frozen fails when the lock file is missing" {
  $ GIT_CONFIG_GLOBAL=/dev/null GIT_CONFIG_NOSYSTEM=1 git init --quiet --initial-branch main source-repo
  $ git -C source-repo config user.email "e2e@example.com"
  $ git -C source-repo config user.name "e2e"
  write <"source-repo/skills/demo-skill/SKILL.md"> ```
    ---
    name: demo-skill
    description: demo skill resolved over git transport
    ---

    # Demo Skill
    ```
  $ GIT_CONFIG_GLOBAL=/dev/null GIT_CONFIG_NOSYSTEM=1 git -C source-repo add --all
  $ GIT_CONFIG_GLOBAL=/dev/null GIT_CONFIG_NOSYSTEM=1 git -C source-repo commit --quiet -m only
  write <"enozunu.kdl"> ```
    enozunu config-version=1 {
      provider {
        skills {
          skill "demo-skill" {
            git {
              url "SOURCE_URL"
              branch "main"
              path "skills/demo-skill"
            }
          }
        }
      }
      consumer {
        claude {
          use-skills "demo-skill"
        }
      }
    }
    ```
  $ sed -i "s|SOURCE_URL|file://$PWD/source-repo|" enozunu.kdl
  # Positive control: the fixture repository exists and the manifest points at
  # it, so the failure below can only come from the missing lock file.
  $ git -C source-repo rev-parse HEAD
  assert {
    exit 0
    not {
      file <"enozunu.kdl"> contains "SOURCE_URL"
    }
  }
  $ enozunu summon --frozen
  assert {
    exit 1
    stderr contains "lock-out-of-date"
    # A failed frozen run materializes nothing and never creates the lock it
    # reported missing.
    not {
      dir <".claude"> exists
    }
    not {
      file <"enozunu.lock.json"> exists
    }
  }
}
