# E2E: `enozunu validate` accepts a well-formed manifest and reports read/syntax failures.

case "validate accepts a freshly initialized manifest" {
  $ enozunu init
  $ enozunu validate
  assert {
    exit 0
    stdout contains "is valid"
  }
}

case "validate reports a missing manifest" {
  $ enozunu validate
  assert {
    exit 1
    stderr contains "failed to read"
  }
}

case "validate rejects a manifest that is not valid KDL" {
  write <"enozunu.kdl"> "not a valid manifest {{{"
  $ enozunu validate
  assert {
    exit 1
    stderr contains "not valid KDL"
  }
}

case "validate rejects valid KDL that is not a valid manifest" {
  write <"enozunu.kdl"> "enozunu config-version=1 { bogus-block {} }"
  $ enozunu validate
  assert {
    exit 1
    stderr contains "unknown block"
  }
}
