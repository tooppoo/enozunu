// Enozunu manifest.
enozunu config-version=1 {
  provider {
    skills {
      skill "subagent-review-loop" {
        git {
          url "https://github.com/tooppoo/catalog-agent-tools"
          branch "main"
          path "common/skills/subagent-review-loop"
        }
      }

      skill "documentation-writing" {
        git {
          url "https://github.com/tooppoo/catalog-agent-tools"
          branch "main"
          path "common/skills/documentation-writing"
        }
      }

      skill "code-comment" {
        git {
          url "https://github.com/tooppoo/catalog-agent-tools"
          branch "main"
          path "common/skills/code-comment"
        }
      }

      skill "cli-output-design" {
        git {
          url "https://github.com/tooppoo/catalog-agent-tools"
          branch "main"
          path "common/skills/cli-output-design"
        }
      }

      skill "reportage" {
        git {
          url "https://github.com/tooppoo/catalog-agent-tools"
          branch "main"
          path "common/skills/reportage"
        }
      }
    }

    // agents {
    //   agent "example-agent" {
    //     git {
    //       url "https://github.com/your-org/your-agents-repo"
    //       branch "main"
    //       path "path/to/agents/example-agent.md"
    //     }
    //   }
    // }
  }

  // `consumer` selects what to materialize for each target AI.
  consumer {
    claude {
      use-skills "documentation-writing" \
        "subagent-review-loop" \
        "code-comment" \
        "cli-output-design" \
        "reportage"
    }
  }
}
